{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/spac/artifact-manifest.schema.json",
  "title": "SPAC artifact manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "tool_name",
    "tool_version",
    "input_files",
    "output_files"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "spac.artifact-manifest.v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "input_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact_file"
      }
    },
    "output_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact_file"
      }
    }
  },
  "$defs": {
    "artifact_file": {
      "type": "object",
      "required": ["path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
