{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/spac/hls-csim-run.schema.json",
  "title": "SPAC HLS csim smoke run",
  "type": "object",
  "required": [
    "schema_version",
    "protocol_name",
    "board_profile_id",
    "trust_level",
    "status",
    "package_files",
    "manifest_path",
    "command",
    "tool",
    "limitations",
    "diagnostics"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "spac.hls-csim-run.v0"
    },
    "protocol_name": {
      "type": "string",
      "minLength": 1
    },
    "board_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "trust_level": {
      "enum": ["software_model", "hls_csim"]
    },
    "status": {
      "enum": ["success", "failure", "blocked"]
    },
    "package_files": {
      "type": "object",
      "required": [
        "packet_header_path",
        "smoke_source_path",
        "hls_config_path",
        "run_tcl_path",
        "log_paths"
      ],
      "additionalProperties": false,
      "properties": {
        "packet_header_path": {
          "type": "string",
          "minLength": 1
        },
        "smoke_source_path": {
          "type": "string",
          "minLength": 1
        },
        "hls_config_path": {
          "type": "string",
          "minLength": 1
        },
        "run_tcl_path": {
          "type": "string",
          "minLength": 1
        },
        "log_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "object",
      "required": [
        "declared_family",
        "declared_version",
        "requested_binary",
        "exit_code"
      ],
      "additionalProperties": false,
      "properties": {
        "declared_family": {
          "type": "string",
          "minLength": 1
        },
        "declared_version": {
          "type": "string",
          "minLength": 1
        },
        "requested_binary": {
          "type": ["string", "null"]
        },
        "exit_code": {
          "type": ["integer", "null"]
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "code", "message", "path"],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "enum": ["error", "warning"]
          },
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
