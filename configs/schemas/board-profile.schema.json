{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/spac/board-profile.schema.json",
  "title": "SPAC FPGA board profile",
  "type": "object",
  "required": [
    "schema_version",
    "board_id",
    "vendor",
    "board_model",
    "fpga_part",
    "toolchain",
    "target_clock_mhz",
    "host_interface",
    "loopback_topology",
    "report_locations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "spac.board-profile.v0"
    },
    "board_id": {
      "type": "string",
      "minLength": 1
    },
    "vendor": {
      "type": "string",
      "minLength": 1
    },
    "board_model": {
      "type": "string",
      "minLength": 1
    },
    "fpga_part": {
      "type": "string",
      "minLength": 1
    },
    "toolchain": {
      "type": "object",
      "required": ["family", "version"],
      "additionalProperties": false,
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target_clock_mhz": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "host_interface": {
      "type": "string",
      "minLength": 1
    },
    "loopback_topology": {
      "type": "string",
      "minLength": 1
    },
    "report_locations": {
      "type": "object",
      "required": ["synthesis_summary", "timing_summary"],
      "additionalProperties": false,
      "properties": {
        "synthesis_summary": {
          "type": "string",
          "minLength": 1
        },
        "timing_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
