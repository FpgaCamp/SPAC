{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/spac/hw-report.schema.json",
  "title": "SPAC FPGA hardware report evidence",
  "type": "object",
  "required": [
    "schema_version",
    "trust_level",
    "tool",
    "board_profile_id",
    "board_model",
    "fpga_part",
    "toolchain_family",
    "toolchain_version",
    "source_report_path",
    "metrics",
    "warnings",
    "limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "spac.hw-report.v0"
    },
    "trust_level": {
      "const": "post_synthesis"
    },
    "tool": {
      "enum": ["vitis", "vivado"]
    },
    "board_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "board_model": {
      "type": "string",
      "minLength": 1
    },
    "fpga_part": {
      "type": "string",
      "minLength": 1
    },
    "toolchain_family": {
      "type": "string",
      "minLength": 1
    },
    "toolchain_version": {
      "type": "string",
      "minLength": 1
    },
    "source_report_path": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "object",
      "required": [
        "lut",
        "ff",
        "bram",
        "dsp",
        "fmax_mhz",
        "initiation_interval",
        "latency_cycles_min",
        "latency_cycles_max",
        "throughput_gbps"
      ],
      "additionalProperties": false,
      "properties": {
        "lut": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "ff": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "bram": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "dsp": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "fmax_mhz": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0
        },
        "initiation_interval": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "latency_cycles_min": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "latency_cycles_max": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "throughput_gbps": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0
        }
      }
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
