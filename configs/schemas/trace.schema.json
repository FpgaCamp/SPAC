{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/spac/trace.schema.json",
  "title": "SPAC normalized workload trace",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "workload_class",
    "time_unit",
    "packets"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "spac.trace.v0"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "workload_class": {
      "enum": [
        "hft",
        "rl_all_reduce",
        "datacenter",
        "industrial",
        "underwater_sensor"
      ]
    },
    "time_unit": {
      "const": "ns"
    },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trace_packet"
      }
    }
  },
  "$defs": {
    "trace_packet": {
      "type": "object",
      "required": [
        "timestamp_ns",
        "ingress_port",
        "src",
        "dst",
        "payload_bytes",
        "flow_id"
      ],
      "additionalProperties": false,
      "properties": {
        "timestamp_ns": {
          "type": "integer",
          "minimum": 0
        },
        "ingress_port": {
          "type": "integer",
          "minimum": 0
        },
        "src": {
          "type": "integer",
          "minimum": 0
        },
        "dst": {
          "type": "integer",
          "minimum": 0
        },
        "payload_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "flow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
