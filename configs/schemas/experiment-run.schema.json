{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/spac/experiment-run.schema.json",
  "title": "SPAC experiment run bundle",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "stage",
    "trust_level",
    "status",
    "artifact_manifest_schema",
    "command",
    "board_profile_id",
    "input_files",
    "output_files",
    "known_limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "spac.experiment-run.v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "enum": ["E0", "E1", "E2", "E3", "E4", "E5", "E6", "E7", "E8"]
    },
    "trust_level": {
      "enum": [
        "software_model",
        "hls_csim",
        "post_synthesis",
        "hardware_measured"
      ]
    },
    "status": {
      "enum": ["success", "failure", "blocked"]
    },
    "artifact_manifest_schema": {
      "const": "spac.artifact-manifest.v0"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "board_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "input_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_file"
      }
    },
    "output_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_file"
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "artifact_file": {
      "type": "object",
      "required": ["path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
